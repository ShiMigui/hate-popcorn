{
  "name": "miguel/hatepopcorn-api",
  "type": "project",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Hatepopcorn\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Miguel Nascimento",
      "email": "miguel.nasto@gmail.com"
    }
  ],
  "require": {
    "nikic/fast-route": "^1.3",
    "monolog/monolog": "^3.10",
    "ext-pdo_pgsql": "*",
    "ext-pdo": "*",
    "firebase/php-jwt": "^7.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.94"
  },
  "scripts": {
    "fix:check": "php-cs-fixer fix --dry-run --diff",
    "analyse": "phpstan analyse src --level=7",
    "fix": "php-cs-fixer fix",
    "test": "phpunit"
  }
}
